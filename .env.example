# ══════════════════════════════════════════════════════
#  .env.example — 환경변수 템플릿
#  이 파일을 복사해서 .env 로 저장 후 값을 채우세요.
#  .env 파일은 절대 git에 커밋하지 마세요!
# ══════════════════════════════════════════════════════

# [필수] JWT 서명 키 — 최소 32자 이상의 랜덤 문자열
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=여기에_최소32자이상의_랜덤문자열을_입력하세요

# [필수] PostgreSQL 연결 URL (Neon 사용 시 대시보드에서 복사)
# 형식: postgresql://유저명:비밀번호@호스트/DB이름?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# [선택] CORS 허용 origin (콤마로 구분)
# Flutter Web 배포 시 해당 URL 추가
ALLOWED_ORIGINS=http://localhost:3000

# [선택] Access token 만료 시간 (분, 기본 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# [선택] 로그인 실패 허용 횟수 (기본 5)
MAX_LOGIN_ATTEMPTS=5

# [선택] 계정 잠금 시간 (분, 기본 15)
LOGIN_LOCKOUT_MINUTES=15

# [선택] 프로덕션 환경 여부
IS_PRODUCTION=true

# ── 이메일 설정 (비밀번호 재설정용) ─────────────────────────
# Gmail 앱 비밀번호 발급: https://myaccount.google.com/apppasswords
# (2단계 인증 활성화 후 앱 비밀번호 → StageMate 생성)
MAIL_USERNAME=yourname@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM=yourname@gmail.com
MAIL_FROM_NAME=StageMate
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
